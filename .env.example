# ─────────────────────────────────────────────────────────
# Com-Plan-ion · Environment Configuration
# Copy to .env.local to run locally
# ─────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────
# Set to "true" to run entirely with mock data (no API keys needed)
MOCK_MODE=true

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Gemini (Google AI) ────────────────────────────────────
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── MongoDB Atlas ─────────────────────────────────────────
# Get connection string from: https://cloud.mongodb.com
# Required collections: events, eventMemory, vendors, guests, budgets, timelineItems, aiInsights, voiceLogs, tickets
MONGODB_URI=
MONGODB_DB_NAME=complanion

# Atlas Vector Search index config (see README for setup):
# Collection: vendors | Index name: vendor_embedding
# numDimensions: 768 | similarity: cosine | path: embeddingVector

# ── ElevenLabs ────────────────────────────────────────────
# Get API key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional: Clone the organizer's voice at https://elevenlabs.io/voice-lab
ELEVENLABS_CLONED_VOICE_ID=

# ── Solana ────────────────────────────────────────────────
# Custom RPC (optional, defaults to devnet public RPC)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Server-side wallet keypair for minting (base58 encoded)
# Generate with: solana-keygen new --outfile /tmp/mint-keypair.json
SOLANA_MINT_KEYPAIR=

# Metaplex Tree address for compressed NFTs (Bubblegum)
SOLANA_MERKLE_TREE_ADDRESS=
